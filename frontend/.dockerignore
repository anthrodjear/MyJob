# Secrets — never bake into image layers
.env
.env.*
!.env.example

# Git
.git/
.gitignore

# Dependencies (installed inside image via npm ci)
node_modules/

# Next.js build output (generated during image build)
.next/
out/
.vercel/

# Test files (not needed in production image)
coverage/
.nyc_output/
__tests__/
__mocks__/
playwright-report/
test-results/
.vitest/

# AI agent context
../context/
../AGENTS.md
../CLAUDE.md
../docs/
../.config/
../.agents/
../.opencode/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/
npm-debug.log*

# Docker
Dockerfile*
.dockerignore
docker-compose*.yml

# Documentation
*.md
LICENSE
