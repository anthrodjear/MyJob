../context/
../AGENTS.md
../CLAUDE.md
../docs/
../.config/
../.agents/
../.opencode/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Docker
Dockerfile*
.dockerignore
docker-compose*.yml

# Documentation
*.md
LICENSE
