# ============================================
# Database
# ============================================
DATABASE_URL=postgres://myjob:myjob_dev@localhost:5432/myjob?sslmode=disable
POSTGRES_PASSWORD=myjob_dev
REDIS_URL=redis://localhost:6379

# ============================================
# Auth (REQUIRED - no defaults)
# ============================================
# Generate password hash: echo "yourpassword" | bcrypt
# Or use: go run scripts/hash_password.go "yourpassword"
AUTH_PASSWORD_HASH=
# Generate secret: openssl rand -hex 32
AUTH_JWT_SECRET=

# ============================================
# LLM API Keys (REQUIRED for AI features)
# ============================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: override model versions
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4
OLLAMA_MODEL=qwen2.5:latest
OLLAMA_EMBED_MODEL=mxbai-embed-large

# ============================================
# Microsoft Graph (Optional - for email sync)
# ============================================
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
EMAIL_FOLDERS=Inbox,Jobs,Applications

# ============================================
# LiveKit (Voice Interview Coach)
# ============================================
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ============================================
# Ollama (Local LLM)
# ============================================
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# Queue & Rate Limiting
# ============================================
QUEUE_CONCURRENCY=5
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# ============================================
# App
# ============================================
APP_ENV=development

# ============================================
# Grafana
# ============================================
GRAFANA_PASSWORD=admin

# ============================================
# Database Tuning (Optional)
# ============================================
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5