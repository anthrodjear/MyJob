# ============================================
# Database
# ============================================
DATABASE_URL=postgres://myjob:myjob_dev@localhost:5432/myjob?sslmode=disable
POSTGRES_PASSWORD=myjob_dev
REDIS_URL=redis://localhost:6379

# ============================================
# Auth
# ============================================
# Auto-generated by: bash scripts/setup-env.sh
# Or manually: echo "yourpassword" | htpasswd -nbBC 10 "" - | cut -d: -f2
# Default password: admin
AUTH_PASSWORD_HASH=
AUTH_JWT_SECRET=

# Next.js session cookie secret (≥32 chars, used by lib/session.ts)
# Separate from AUTH_JWT_SECRET — this encrypts the HTTP-only session cookie
SESSION_SECRET=

# ============================================
# LLM API Keys (REQUIRED for AI features)
# ============================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: override model versions
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4
OLLAMA_MODEL=qwen2.5:latest
OLLAMA_EMBED_MODEL=mxbai-embed-large

# ============================================
# Microsoft Graph (Optional - for email sync)
# ============================================
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
EMAIL_FOLDERS=Inbox,Jobs,Applications

# ============================================
# LiveKit (Voice Interview Coach)
# ============================================
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
# LIVEKIT_FLAGS: flags passed to livekit-server (e.g., --dev for local dev)
# Default: --dev (set empty for production)
LIVEKIT_FLAGS=--dev

# ============================================
# Ollama (Local LLM — runs on host, not in Docker)
# ============================================
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# Queue & Rate Limiting
# ============================================
QUEUE_CONCURRENCY=5
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# ============================================
# App
# ============================================
APP_ENV=development

# ============================================
# Grafana
# ============================================
GRAFANA_PASSWORD=admin

# ============================================
# Database Tuning (Optional)
# ============================================
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5